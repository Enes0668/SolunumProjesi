@page "/"
@rendermode InteractiveServer
@using SolunumProjesi.Models
@using SolunumProjesi.Services
@inject AtakKaydiCsvService CsvService
@inject AISimulationService AiService
@inject MLModelService MlService

<PageTitle>Solunum Projesi - Yönetim Paneli</PageTitle>

<div class="dashboard-container">
    <header class="dashboard-header">
        <div class="header-titles">
            <h1>Solunum Projesi Yönetim Paneli</h1>
            <p>Hastaların atak kayıtlarını ve semptom detaylarını analiz edin.</p>
        </div>

        <div class="header-actions">
            <label class="btn btn-primary upload-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
                CSV Yükle
                <InputFile OnChange="LoadFiles" accept=".csv" class="hidden-input" />
            </label>
        </div>
    </header>

    <div class="dashboard-content">
        <!-- Main Table Section -->
        <main class="table-section @(selectedRecord != null ? "panel-open" : "")">
            @if (isLoading)
            {
                <div class="empty-state">
                    <div class="spinner"></div>
                    <p>Veriler yükleniyor...</p>
                </div>
            }
            else if (Veriler == null || !Veriler.Any())
            {
                <div class="empty-state">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#cfd8dc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    <p>Lütfen verileri görüntülemek için bir CSV dosyası yükleyin.</p>
                </div>
            }
            else
            {
                <div class="table-card glass-panel">
                    <table class="modern-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Peak Flow</th>
                                <th>Uzman Etiketi</th>
                                <th>ML Modeli</th>
                                <th>Gemini AI</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var kayit in Veriler)
                            {
                                <tr class="@(selectedRecord?.Id == kayit.Id ? "selected-row" : "")" @onclick="() => SelectRecord(kayit)">
                                    <td><strong>#@kayit.Id</strong></td>
                                    <td>
                                        <div class="peak-flow-indicator">
                                            <div class="indicator-bg">
                                                <div class="indicator-bar @GetPeakFlowColor(kayit.PeakFlowValue)" style="width: @(Math.Min(kayit.PeakFlowValue, 100))%"></div>
                                            </div>
                                            <span class="peak-value">@kayit.PeakFlowValue</span>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge @GetBadgeClass(kayit.UzmanEtiketi)">@kayit.UzmanEtiketi</span>
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(kayit.MLEtiketi))
                                        {
                                            <span class="badge @GetBadgeClass(kayit.MLEtiketi)">@kayit.MLEtiketi</span>
                                        }
                                        else
                                        {
                                            <span style="color:#555; font-size:12px;">—</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(kayit.AIEtiketi))
                                        {
                                            <span class="badge @GetBadgeClass(kayit.AIEtiketi)">@kayit.AIEtiketi</span>
                                        }
                                        else
                                        {
                                            <span style="color:#555; font-size:12px;">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </main>

        <!-- Right Side Details Panel -->
        <aside class="side-panel @(selectedRecord != null ? "open" : "") glass-panel">
            @if (selectedRecord != null)
            {
                <div class="panel-header">
                    <h2>Kayıt Detayı <span>#@selectedRecord.Id</span></h2>
                    <button class="close-btn" @onclick="ClosePanel">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                    </button>
                </div>

                <div class="panel-body">
                    <div class="detail-group">
                        <label>Semptomlar</label>
                        <div class="symptom-card">
                            <p>@selectedRecord.Semptomlar</p>
                        </div>
                    </div>

                    <div class="detail-group">
                        <label>Uzman Değerlendirmesi</label>
                        <div class="badge-container">
                            <span class="badge @GetBadgeClass(selectedRecord.UzmanEtiketi) badge-lg">@selectedRecord.UzmanEtiketi</span>
                        </div>
                    </div>

                    <!-- ML Model Sonucu -->
                    @if (!string.IsNullOrEmpty(selectedRecord.MLEtiketi))
                    {
                        <div class="detail-group">
                            <label>ML Modeli Tahmini</label>
                            <div style="display:flex; align-items:center; gap:10px; flex-wrap:wrap;">
                                <span class="badge @GetBadgeClass(selectedRecord.MLEtiketi) badge-lg">@selectedRecord.MLEtiketi</span>
                                @{
                                    bool mlUyum = string.Equals(selectedRecord.MLEtiketi, selectedRecord.UzmanEtiketi, StringComparison.OrdinalIgnoreCase);
                                }
                                <span style="font-size:13px; color: @(mlUyum ? "#4caf50" : "#f44336");">
                                    @(mlUyum ? "✔ Uzmanla uyumlu" : "✘ Uzmanla farklı")
                                </span>
                            </div>
                        </div>
                    }

                    <!-- Gemini AI Bölümü -->
                    <div class="detail-group ai-section">
                        <label>Yapay Zeka Analizi <span class="beta-tag">BETA</span></label>

                        @if (string.IsNullOrEmpty(selectedRecord.AIEtiketi))
                        {
                            <div class="ai-empty">
                                <p>Bu kayıt için derinlemesine yapay zeka analizi yaparak gizli örüntüleri keşfedebilirsiniz.</p>
                                <button class="btn btn-magic ai-btn" @onclick="StartAIAnalysis" disabled="@isAnalyzing">
                                    @if (isAnalyzing)
                                    {
                                        <div class="spinner-small"></div>
                                        <span>Analiz Ediliyor...</span>
                                    }
                                    else
                                    {
                                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                                        <span>Gemini Analizini Başlat</span>
                                    }
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="ai-result slide-in">
                                <div class="ai-result-header">
                                    <strong>Gemini Tahmini:</strong>
                                    <span class="badge ai-badge">@selectedRecord.AIEtiketi</span>
                                </div>
                                <div class="ai-reason">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="16" x2="12" y2="12"></line><line x1="12" y1="8" x2="12.01" y2="8"></line></svg>
                                    <p>@selectedRecord.AIGerekce</p>
                                </div>

                                <!-- Üçlü Karşılaştırma -->
                                <div style="margin-top:15px; padding:12px; background:rgba(255,255,255,0.05); border-radius:8px;">
                                    <h4 style="margin:0 0 10px 0; font-size:14px; color:#a0aec0;">Üçlü Karşılaştırma</h4>
                                    <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:8px; text-align:center;">
                                        <div>
                                            <div style="font-size:11px; color:#a0aec0; margin-bottom:4px;">UZMAN</div>
                                            <span class="badge @GetBadgeClass(selectedRecord.UzmanEtiketi)">@selectedRecord.UzmanEtiketi</span>
                                        </div>
                                        <div>
                                            <div style="font-size:11px; color:#a0aec0; margin-bottom:4px;">ML MODELİ</div>
                                            <span class="badge @GetBadgeClass(selectedRecord.MLEtiketi)">@(string.IsNullOrEmpty(selectedRecord.MLEtiketi) ? "—" : selectedRecord.MLEtiketi)</span>
                                        </div>
                                        <div>
                                            <div style="font-size:11px; color:#a0aec0; margin-bottom:4px;">GEMİNİ</div>
                                            <span class="badge ai-badge">@selectedRecord.AIEtiketi</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </aside>
    </div>
</div>

@code {
    private List<AtakKaydi> Veriler;
    private AtakKaydi selectedRecord;
    private bool isLoading = false;
    private bool isAnalyzing = false;

    protected override void OnInitialized()
    {
        if (CsvService.GuncelVeriler != null)
        {
            Veriler = CsvService.GuncelVeriler;
        }
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var tempFile = Path.GetTempFileName();
            await using FileStream fs = new(tempFile, FileMode.Create);
            await e.File.OpenReadStream(1024 * 1024 * 5).CopyToAsync(fs);
            fs.Close();

            Veriler = CsvService.ReadVeriler(tempFile);
            selectedRecord = null;
            isAnalyzing = false;

            try { File.Delete(tempFile); } catch { }

            // Mock CSV ile önceden eğitilmiş modelle tahmin yap
            MlService.TahminEt(Veriler);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error uploading file: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SelectRecord(AtakKaydi kayit)
    {
        selectedRecord = kayit;
        isAnalyzing = false;
    }

    private void ClosePanel()
    {
        selectedRecord = null;
    }

    private async Task StartAIAnalysis()
    {
        if (selectedRecord == null) return;

        isAnalyzing = true;
        StateHasChanged();

        var yapayZekaSonucu = await AiService.AnalizYapAsync(selectedRecord);
        selectedRecord.AIEtiketi = yapayZekaSonucu.Etiket;
        selectedRecord.AIGerekce = yapayZekaSonucu.Gerekce;

        isAnalyzing = false;
    }

    private string GetBadgeClass(string etiketi)
    {
        if (string.IsNullOrEmpty(etiketi)) return "badge-default";
        return etiketi.ToLower() switch
        {
            var e when e.Contains("hafif") => "badge-success",
            var e when e.Contains("orta") => "badge-warning",
            var e when e.Contains("siddetli") || e.Contains("şiddetli") => "badge-danger",
            _ => "badge-default"
        };
    }

    private string GetPeakFlowColor(int value)
    {
        if (value > 80) return "bg-success";
        if (value > 50) return "bg-warning";
        return "bg-danger";
    }
}
